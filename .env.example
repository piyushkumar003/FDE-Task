# GEMINI_API_KEY or FDE: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"
FDE="MY_GEMINI_API_KEY_OR_FDE"

# APP_URL: The URL where this applet/application is hosted.
APP_URL="MY_APP_URL"

# GOOGLE_CLIENT_ID: Google OAuth 2.0 Client ID for Workspace API integration
GOOGLE_CLIENT_ID="MY_GOOGLE_CLIENT_ID"

# GOOGLE_CLIENT_SECRET: Google OAuth 2.0 Client Secret
GOOGLE_CLIENT_SECRET="MY_GOOGLE_CLIENT_SECRET"

# GOOGLE_REDIRECT_URI: Google OAuth 2.0 Redirect URI
GOOGLE_REDIRECT_URI="https://fdeautomate.netlify.app/api/auth/callback"

# SESSION_SECRET: Secret for signing sessions
SESSION_SECRET="your_random_secret"

# NODE_ENV: Environment mode (production / development)
NODE_ENV="production"
